{
  "name": "astrology-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@react-pdf/renderer": "^4.3.1",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "gtag": "^1.0.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^1.4.4",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.4",
    "react-scripts": "5.0.1",
    "react-toastify": "^9.1.3",
    "recharts": "^3.7.0",
    "styled-components": "^6.1.0"
  },
  "scripts": {
    "refresh:browserslist": "npx update-browserslist-db@latest",
    "start": "PORT=3001 craco start",
    "build": "craco build && npm run build:karma-next && node scripts/postbuild-seo.mjs",
    "build:karma-next": "cd ../frontend-next && npm install && npm run build && node scripts/copy-to-cra-build.mjs",
    "serve:build": "node scripts/serve-build.mjs",
    "build:app": "craco build",
    "build:seo": "node scripts/postbuild-seo.mjs",
    "build:dev": "NODE_ENV=development craco build",
    "build:prod": "NODE_ENV=production GENERATE_SOURCEMAP=false INLINE_RUNTIME_CHUNK=true craco build && npm run build:karma-next && node scripts/postbuild-seo.mjs"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "puppeteer": "^24.43.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "proxy": "http://localhost:8001"
}
