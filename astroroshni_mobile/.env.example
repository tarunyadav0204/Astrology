# Sentry (crash reporting)
EXPO_PUBLIC_SENTRY_DSN=

# Meta / Facebook App Events (Meta Events Manager → your app → Settings)
# App ID: Settings → Basic. Client token: Settings → Advanced → Client token.
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=
# Set to 1 to print [FB_EVENTS] lines to logcat (ReactNativeJS) in release builds too.
EXPO_PUBLIC_FACEBOOK_DEBUG_LOG=
