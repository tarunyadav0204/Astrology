{
  "expo": {
    "name": "AstroRoshni",
    "slug": "astroroshni-mobile",
    "version": "1.2.4",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f97316"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.astroroshni.mobile",
      "buildNumber": "106",
