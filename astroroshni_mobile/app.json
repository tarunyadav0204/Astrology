      "bitcode": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSMicrophoneUsageDescription": "AstroRoshni uses the microphone so you can ask chat questions by speaking.",
        "NSSpeechRecognitionUsageDescription": "AstroRoshni uses speech recognition to turn your spoken question into text.",
        "UIBackgroundModes": [
          "audio"
        ],
        "UILaunchScreen": {}
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f97316"
      },
      "package": "com.astroroshni.mobile",
