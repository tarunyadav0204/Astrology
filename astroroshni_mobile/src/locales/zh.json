    "ascendantDescriptions": {
      "Aries": "受火星主宰。体质活跃，具有运动天赋。您以开拓和果断的态度对待世界。外在表现独立、坦率且坚决。",
      "Taurus": "受金星主宰。拥有稳重、扎实的身体素质。外在表现稳健、有条不紊。天生追求物质保障和实际成果。",
      "Gemini": "受水星主宰。外貌常保年轻，动作敏捷。通过交流和适应能力与世界互动。擅长同时处理多项任务。",
      "Cancer": "受月亮主宰。体质柔软，情感丰富。以谨慎、保护性的本能观察世界。行为很大程度上受保护家庭和亲近的人所驱动。",
      "Leo": "受太阳主宰。姿态威严挺拔，拥有强大的气场。以天生的权威和生命力与外界互动。寻求关注和领导角色。",
      "Virgo": "受水星主宰。外表整洁，观察力敏锐。通过分析和务实的务来度过人生。行为精确且注重细节。",
      "Libra": "受金星主宰。五官对称，具有天然的魅力和外交手段。追求平衡，避免冲突。侧重于建立伙伴关系和维持社会和谐。",
      "Scorpio": "受火星主宰。体质坚韧，眼神深邃。行事谨慎，常隐藏真实动机。意志坚定，具有强大的转化能力。",
      "Sagittarius": "受木星主宰。身形高大，生性好动。通过扩张和探索的视角看待世界。外在表现乐观，不断追求高等知识。",
      "Capricorn": "受土星主宰。身形清瘦，显熟稳重。以极大的自律和忍耐力行事。专注于获得长期地位和事业成功。",
      "Aquarius": "受土星主宰。外貌或风格独特。以客观观察者的视角与外界互动。受人道主义理想或系统性思维驱动。",
      "Pisces": "受木星主宰。体质柔软，眼神忧郁梦幻。适应能力极强，直觉敏锐。常被抽象或精神领域所吸引。"
    },
    "moonDescriptions": {
      "Aries": "思维敏捷且充满激情。在独立和直接表达情感中找到安全感。情绪来去匆匆，更愿意向前看。",
      "Taurus": "月亮在此强势。思维追求和平、稳定和感官舒适。处理情感缓慢，在规律、财富和自然中寻找安全感。",
      "Gemini": "思维活跃且好奇。通过理性分析处理情感，在交流和学习中找到慰藉。情绪可能随想法快速变化。",
      "Cancer": "这是月亮的本位星座。内心世界极度敏感且直觉敏锐。在安全的家庭环境和亲密的家庭关系中找到慰藉。",
      "Leo": "思维慷慨且自豪。在被欣赏、被爱和参与创造中找到安全感。情感热烈，渴望被亲近的人认可。",
      "Virgo": "思维严谨、务实。通过整理环境和帮助他人来处理情感。在规律和解决问题中找到慰藉。",
      "Libra": "思维不断寻求平衡与和谐。在和平的环境和稳固的一对一关系中找到情感慰藉。厌恶冲突。",
      "Scorpio": "月亮在此失势。内心世界极度深邃且私密。情感体验极端，在探索隐藏真相和心理深度中找到慰藉。",
      "Sagittarius": "思维乐观且富有哲学性。在自由、旅行和追求真理中找到情感慰藉。不喜欢被沉重的情感要求束缚。",
      "Capricorn": "内心世界严肃自律。通过关注责任和成就来处理情感。在结构和掌控中找到慰藉。",
      "Aquarius": "思维客观且具有社会意识。理性处理情感，常从旁观者角度看待问题。在理想和友谊中找到慰藉。",
      "Pisces": "内心世界富有想象力和同情心。情感边界模糊，容易感同身受。在艺术和冥想中找到慰藉。"
    },
    "sunDescriptions": {
      "Aries": "太阳在此强势。核心身份勇敢独立。灵魂目标是领导、克服挑战和发起行动。拥有强大的权威。",
      "Taurus": "核心身份稳健。灵魂目标是建立持久的稳定性，无论是通过财富、家庭还是艺术。投影出安静的力量。",
      "Gemini": "核心身份侧重于智力和交流。灵魂目标围绕收集知识、建立网络和表达思想。受逻辑驱动。",
      "Cancer": "核心身份极具保护性且情感根基深厚。灵魂目标是通过同理心来培养、保障和引导。",
      "Leo": "这是太阳的本位星座。核心身份尊贵且充满创造活力。灵魂目标是闪耀、领导和激励他人。",
      "Virgo": "核心身份纯粹且侧重于服务。灵魂目标是改善、组织和治愈。从才干和辛勤工作中获得自我价值感。",
      "Libra": "太阳在此失势。核心身份与伙伴关系及和谐挂钩。灵魂目标是创造平衡与公正，常把他人需求置于自我之上。",
      "Scorpio": "核心身份强烈且具有转化力。灵魂目标涉及揭示隐藏真相、负责任地行使权力和经历深刻的自我蜕变。",
      "Sagittarius": "核心身份乐观且受道德准则引导。灵魂目标是寻求更高智慧、教学和探索。热爱真理。",
      "Capricorn": "核心身份自律且务实。灵魂目标是获得实际成功、地位和架构权威。通过耐心和忍耐建立自我。",
      "Aquarius": "核心身份侧重于集体。灵魂目标是服务人类，挑战陈旧结构并传播进步思想。常为大局牺牲个人小我。",
      "Pisces": "核心身份富有同情心且无边界。灵魂目标是超越物质世界，提供同理心和神圣的爱。身份具有流动性。"
    },
