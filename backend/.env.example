# Sentry (optional — create a Python project at https://sentry.io)
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

### Local Postgres (Docker)
# Start DB:
#   docker compose -f backend/docker-compose.yml up -d
#
# Default credentials come from backend/docker-compose.yml.
# Change password in BOTH places if you change it.
POSTGRES_DSN=postgresql://astroroshni_app:astroroshni_dev_password@127.0.0.1:5432/astroroshni

# Gemini AI Configuration
GEMINI_API_KEY=AIzaSyA4H9-htLcBpwHkOGIBBG-QAUBVqHTTZe0

# Add this to your .env file with your actual Gemini API key
# Get your API key from: https://makersuite.google.com/app/apikey

# Chat wait engagement snippets
# Off by default. Set to true only when the in-chat interim conversation UX is ready.
CHAT_WAIT_ENGAGEMENT_ENABLED=false

# Chat wait side conversation
# Off by default. Enables a temporary user/assistant conversation while the final answer is processing.
CHAT_WAIT_SIDE_CONVERSATION_ENABLED=false
# Uses Gemini CachedContent for the immutable chart/dasha/transit context across side-conversation turns.
CHAT_WAIT_SIDE_GEMINI_CACHE_ENABLED=true
CHAT_WAIT_SIDE_GEMINI_CACHE_TTL_S=900

# GCP project (required for admin Activity tab / BigQuery; optional for Pub/Sub topic)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Razorpay (web credit purchases — INR Checkout)
# Dashboard: https://dashboard.razorpay.com → API Keys + Webhooks
# RAZORPAY_KEY_ID=rzp_live_xxxx
# RAZORPAY_KEY_SECRET=xxxx
# Webhook URL: POST https://your-api-host/api/credits/razorpay/webhook — event: payment.captured
# RAZORPAY_WEBHOOK_SECRET=xxxx

# WhatsApp Cloud API (Meta Developer → WhatsApp → Configuration → Webhook)
# Callback URL: https://your-api-host/api/webhooks/whatsapp
# WHATSAPP_VERIFY_TOKEN=choose-a-long-random-string-matching-meta-dashboard
# App secret (Meta app → App settings → Basic); used to validate X-Hub-Signature-256 on POST:
# WHATSAPP_APP_SECRET=xxxx
# Outbound WhatsApp replies (Graph API): System User token or API Setup temporary token
# WHATSAPP_ACCESS_TOKEN=EA...
# WHATSAPP_GRAPH_API_VERSION=v22.0

# --- WhatsApp Flow (optional): "Add new chart" opens Flow instead of URL-only ---
# Create + publish a Flow in WhatsApp Manager, then set ONE of:
# WHATSAPP_BIRTHCHART_FLOW_ID=1234567890
# WHATSAPP_BIRTHCHART_FLOW_NAME=my_birth_chart_flow
# WHATSAPP_BIRTHCHART_FLOW_CTA=Add birth details
# WHATSAPP_BIRTHCHART_FLOW_MODE=published
# WHATSAPP_BIRTHCHART_FLOW_BODY=Tap the button and complete the form to add a birth chart.
# WHATSAPP_BIRTHCHART_FLOW_HEADER=AstroRoshni
# WHATSAPP_BIRTHCHART_FLOW_FOOTER=astroroshni.com
# WHATSAPP_BIRTHCHART_FLOW_SCREEN=FIRST_ENTRY_SCREEN
# Webhooks: subscribe to "messages" (required) and optionally "flows" for Flow health — see backend/whatsapp/FLOWS.md
#
# Flow *data* endpoint (WhatsApp Manager → Flow → Endpoint URL), e.g.:
#   https://your-api-host/api/webhooks/whatsapp-flow
# Register the matching *public* key per phone number:
#   POST https://graph.facebook.com/v22.0/<PHONE_NUMBER_ID>/whatsapp_business_encryption
#   body: business_public_key (x-www-form-urlencoded, full PEM).
# WHATSAPP_FLOW_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# Optional: screen ids / field names for place autocomplete (see backend/whatsapp/FLOWS.md)
# WHATSAPP_FLOW_DATA_INIT_SCREEN=create_birth_chart
# WHATSAPP_FLOW_DATA_SCREEN_SEARCH=place_search
# WHATSAPP_FLOW_DATA_SCREEN_PICK=place_pick
# WHATSAPP_FLOW_DATA_SCREEN_AFTER_PLACE=birth_place_gender
# WHATSAPP_FLOW_DATA_FIELD_PLACE_QUERY=place_query
# WHATSAPP_FLOW_DATA_FIELD_SELECTED_PLACE=selected_place
# Optional: override default prices (amounts in paise, e.g. 4900 = ₹49)
# RAZORPAY_PRICE_PAISE_50=4900
# RAZORPAY_PRICE_PAISE_100=9900
# RAZORPAY_PRICE_PAISE_250=22900
# RAZORPAY_PRICE_PAISE_500=44900
# RAZORPAY_PRICE_PAISE_999=84900
# VIP subscriptions (web / Google alternative billing) — Razorpay plan ids from dashboard:
# RAZORPAY_SUBSCRIPTION_PLAN_SILVER=plan_xxxx
# RAZORPAY_SUBSCRIPTION_PLAN_GOLD=plan_xxxx
# RAZORPAY_SUBSCRIPTION_PLAN_PLATINUM=plan_xxxx
# Or set subscription_plans.razorpay_plan_id in DB. Webhook: also enable subscription.* events.