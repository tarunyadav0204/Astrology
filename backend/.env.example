# Sentry (optional — create a Python project at https://sentry.io)
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

### Local Postgres (Docker)
# Start DB:
#   docker compose -f backend/docker-compose.yml up -d
#
# Default credentials come from backend/docker-compose.yml.
# Change password in BOTH places if you change it.
POSTGRES_DSN=postgresql://astroroshni_app:astroroshni_dev_password@127.0.0.1:5432/astroroshni

# Gemini AI Configuration
GEMINI_API_KEY=AIzaSyA4H9-htLcBpwHkOGIBBG-QAUBVqHTTZe0

# Add this to your .env file with your actual Gemini API key
# Get your API key from: https://makersuite.google.com/app/apikey

# Chat wait engagement snippets
# Off by default. Set to true only when the in-chat interim conversation UX is ready.
CHAT_WAIT_ENGAGEMENT_ENABLED=false

# Chat wait side conversation
# Off by default. Enables a temporary user/assistant conversation while the final answer is processing.
CHAT_WAIT_SIDE_CONVERSATION_ENABLED=false
# Uses Gemini CachedContent for the immutable chart/dasha/transit context across side-conversation turns.
CHAT_WAIT_SIDE_GEMINI_CACHE_ENABLED=true
CHAT_WAIT_SIDE_GEMINI_CACHE_TTL_S=900

# GCP project (required for admin Activity tab / BigQuery; optional for Pub/Sub topic)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Razorpay (web credit purchases — INR Checkout)
# Dashboard: https://dashboard.razorpay.com → API Keys + Webhooks
# RAZORPAY_KEY_ID=rzp_live_xxxx
# RAZORPAY_KEY_SECRET=xxxx
# Webhook URL: POST https://your-api-host/api/credits/razorpay/webhook — event: payment.captured
# RAZORPAY_WEBHOOK_SECRET=xxxx
# Optional: override default prices (amounts in paise, e.g. 4900 = ₹49)
# RAZORPAY_PRICE_PAISE_50=4900
# RAZORPAY_PRICE_PAISE_100=9900
# RAZORPAY_PRICE_PAISE_250=22900
# RAZORPAY_PRICE_PAISE_500=44900
# RAZORPAY_PRICE_PAISE_999=84900